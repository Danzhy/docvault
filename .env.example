DOCVAULT_ENV=local
DOCVAULT_PORT=8000

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=docvault
POSTGRES_USER=docvault
POSTGRES_PASSWORD=docvault
DATABASE_URL=postgresql://docvault:docvault@localhost:5432/docvault

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

DOCVAULT_JWT_SECRET=change-me-in-dotenv
DOCVAULT_JWT_ALGORITHM=HS256
DOCVAULT_ACCESS_TOKEN_EXPIRE_MINUTES=30
DOCVAULT_CACHE_TTL_SECONDS=60
